# Copy to .env (gitignored) before `docker compose up -d`.
#
# Encryption key: n8n encrypts stored credentials with this. Setting it
# explicitly means credentials survive a volume rebuild. Generate one with:
#   openssl rand -hex 24
# or in PowerShell:
#   $c='0123456789abcdef'.ToCharArray(); -join (1..48 | % { $c | Get-Random })
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret

# IANA timezone used by schedule/cron nodes and timestamps.
GENERIC_TIMEZONE=America/Los_Angeles
